# ═══════════════════════════════════════════════════════════════════════════════
#                         HEIMDALL - Guardian of Bifrost
#                         Caddy Reverse Proxy Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# All SSL termination is handled by Cloudflare.
# Heimdall routes incoming HTTP traffic to the appropriate container.
#
# ═══════════════════════════════════════════════════════════════════════════════

{
    # Global options
    admin off
    auto_https off
}

# ─────────────────────────────────────────────────────────────────────────────
# Kanban Board - Project Management (WebSocket enabled)
# ─────────────────────────────────────────────────────────────────────────────
kanban.exe.pm {
    reverse_proxy yggdrasil-kanban:3000
}

# ─────────────────────────────────────────────────────────────────────────────
# Calify - Calendar Feed Transformation
# ─────────────────────────────────────────────────────────────────────────────
calify.it {
    reverse_proxy yggdrasil-calify:3000
}

www.calify.it {
    redir https://calify.it{uri} permanent
}

